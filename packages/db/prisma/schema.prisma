generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum AutonomyLevel {
  OBSERVER
  ADVISOR
  COPILOT
  AUTONOMOUS
}

enum DriverType {
  ENERGIZER
  DRAINER
}

enum GoalCategory {
  PROFESSIONAL
  PERSONAL
}

enum SuggestionMode {
  PERSONAL
  PROFESSIONAL
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  DECLINED
  ACTED
}

enum BalanceDimension {
  WORK
  REST
  SOCIAL
  GROWTH
}

enum ConversationRole {
  USER
  ASSISTANT
}

// ── Models ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personaCard              PersonaCard?
  energyDrivers            EnergyDriver[]
  goals                    Goal[]
  priorities               Priority[]
  autonomySetting          AutonomySetting?
  calendarEvents           CalendarEvent[]
  energyForecasts          EnergyForecast[]
  balanceScores            BalanceScore[]
  suggestions              Suggestion[]
  onboardingConversations  OnboardingConversation[]
}

model PersonaCard {
  id                 String    @id @default(cuid())
  userId             String    @unique
  summary            String
  communicationStyle String
  boundaryNotes      String
  confirmedAt        DateTime?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EnergyDriver {
  id          String     @id @default(cuid())
  userId      String
  label       String
  description String
  driverType  DriverType
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Goal {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String
  category    GoalCategory
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Priority {
  id         String           @id @default(cuid())
  userId     String
  dimension  BalanceDimension
  importance Int
  notes      String?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dimension])
  @@index([userId])
}

model AutonomySetting {
  id               String        @id @default(cuid())
  userId           String        @unique
  level            AutonomyLevel @default(OBSERVER)
  personalMode     AutonomyLevel @default(OBSERVER)
  professionalMode AutonomyLevel @default(OBSERVER)
  updatedAt        DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id        String   @id @default(cuid())
  userId    String
  title     String
  startTime DateTime
  endTime   DateTime
  isDrainer Boolean  @default(false)
  isBooster Boolean  @default(false)
  source    String   @default("manual")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, startTime])
}

model EnergyForecast {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @db.Date
  predictedLevel Int
  reason         String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model BalanceScore {
  id         String           @id @default(cuid())
  userId     String
  dimension  BalanceDimension
  score      Int
  computedAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, computedAt])
}

model Suggestion {
  id                    String           @id @default(cuid())
  userId                String
  mode                  SuggestionMode
  title                 String
  description           String
  reason                String
  status                SuggestionStatus @default(PENDING)
  autonomyLevelRequired AutonomyLevel
  createdAt             DateTime         @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  actions SuggestionAction[]

  @@index([userId])
  @@index([userId, status])
}

model SuggestionAction {
  id           String    @id @default(cuid())
  suggestionId String
  actionType   String
  payload      Json
  executedAt   DateTime?

  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@index([suggestionId])
}

model OnboardingConversation {
  id        String           @id @default(cuid())
  userId    String
  role      ConversationRole
  content   String
  stepIndex Int
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, stepIndex])
}
